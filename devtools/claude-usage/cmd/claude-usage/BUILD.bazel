load("@rules_go//go:def.bzl", "go_binary", "go_library", "go_test")

go_library(
    name = "go_default_library",
    srcs = ["main.go"],
    importpath = "github.com/jaeyeom/experimental/devtools/claude-usage/cmd/claude-usage",
    visibility = ["//visibility:private"],
    deps = [
        "//devtools/claude-usage/internal/claudehud:go_default_library",
        "//devtools/claude-usage/internal/usage:go_default_library",
    ],
)

go_binary(
    name = "claude-usage",
    embed = [":go_default_library"],
    visibility = ["//visibility:public"],
)

go_test(
    name = "go_default_test",
    srcs = ["main_test.go"],
    embed = [":go_default_library"],
    deps = ["//devtools/claude-usage/internal/usage:go_default_library"],
)
